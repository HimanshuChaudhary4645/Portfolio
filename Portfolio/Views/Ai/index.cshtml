<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI Portfolio</title>

    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', sans-serif;
        }

        body {
            height: 100vh;
            background: url('https://images.unsplash.com/photo-1518770660439-4636190af475') no-repeat center center/cover;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
        }

        .overlay {
            position: absolute;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.6);
            backdrop-filter: blur(6px);
        }

        .container {
            position: relative;
            z-index: 2;
            text-align: center;
            width: 90%;
            max-width: 700px;
        }

        h1 {
            font-size: 2.5rem;
            margin-bottom: 10px;
        }

        p {
            opacity: 0.8;
            margin-bottom: 30px;
        }

        /* Search Bar */
        .search-box {
            display: flex;
            background: rgba(255,255,255,0.1);
            border-radius: 50px;
            padding: 10px;
            backdrop-filter: blur(10px);
            box-shadow: 0 0 20px rgba(0,0,0,0.3);
        }

            .search-box input {
                flex: 1;
                border: none;
                background: transparent;
                padding: 10px 15px;
                color: white;
                font-size: 16px;
                outline: none;
            }

            .search-box button {
                background: #00c6ff;
                border: none;
                padding: 10px 20px;
                border-radius: 50px;
                color: white;
                cursor: pointer;
                transition: 0.3s;
            }

                .search-box button:hover {
                    background: #0072ff;
                }

        /* Response Box */
        .response {
            margin-top: 25px;
            text-align: left;
            background: rgba(255,255,255,0.08);
            padding: 15px;
            border-radius: 10px;
            display: none;
            max-height: 200px;
            overflow-y: auto;
        }

        /* Resume Button */
        .resume-btn {
            position: absolute;
            top: 20px;
            right: 20px;
        }

            .resume-btn a {
                text-decoration: none;
                background: #ff7b00;
                padding: 10px 20px;
                border-radius: 25px;
                color: white;
                transition: 0.3s;
            }

                .resume-btn a:hover {
                    background: #ff5500;
                }

        /* Small extra section */
        .footer {
            margin-top: 30px;
            font-size: 14px;
            opacity: 0.7;
        }

    </style>
</head>

<body>

    <div class="overlay"></div>

    <!-- Resume Button -->
    <div class="resume-btn">
        <a href="resume.pdf" download>Download Resume</a>
    </div>

    <div class="container">
        <h1>Hi, I'm Himanshu 👋</h1>
        <p>Ask anything about my skills, experience, or projects</p>

        <!-- Search -->
        <div class="search-box">
            <input type="text" id="query" placeholder="Ask about me... (e.g. skills, projects)">
            <button onclick="askAI()">Search</button>
        </div>

        <!-- Response -->
        <div class="response" id="responseBox"></div>

        <div class="footer">
            Built with ❤️ | AI Powered Portfolio
        </div>
    </div>

    <script>
        function askAI() {
            let input = document.getElementById("query").value;
            let responseBox = document.getElementById("responseBox");

            if (!input) return;

            // Dummy response (replace with API call)
            responseBox.style.display = "block";
            responseBox.innerHTML = "Thinking... 🤖";

            setTimeout(() => {
                responseBox.innerHTML = "You asked: <b>" + input + "</b><br><br>This will connect to OpenAI backend.";
            }, 1000);

            // 🔥 When you connect backend:
            /*
            fetch('/api/ask', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ question: input })
            })
            .then(res => res.json())
            .then(data => {
                responseBox.innerHTML = data.answer;
            });
            */
        }
    </script>

</body>
</html>